# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model to use for token analysis. Haiku is ~20x cheaper than Sonnet and fast
# enough for this use case. Switch to claude-sonnet-4-6 for higher accuracy.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Solana Wallet ─────────────────────────────────────────────────────────────
# Base58-encoded private key (never share this!)
WALLET_PRIVATE_KEY=your_base58_private_key
WALLET_PUBLIC_KEY=your_wallet_public_key

# ── RPC (Helius/QuickNode strongly recommended for production) ────────────────
# Primary endpoint
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Optional comma-separated fallback endpoints. Tried in order when the
# primary RPC fails or rate-limits a transaction.
# SOLANA_RPC_FALLBACK_URLS=https://rpc.ankr.com/solana,https://api.mainnet-beta.solana.com

# ── PumpPortal trading API key (optional, reduces fees) ──────────────────────
PUMPPORTAL_API_KEY=

# ── Risk Management ───────────────────────────────────────────────────────────
MAX_BUY_SOL=0.01
MIN_CONFIDENCE_SCORE=70
TAKE_PROFIT_MULTIPLIER=1.5
STOP_LOSS_MULTIPLIER=0.7
MAX_POSITIONS=3
SLIPPAGE=10
PRIORITY_FEE=0.00001

# ── Token Filtering ───────────────────────────────────────────────────────────
ENABLE_AI_FILTER=true
MIN_INITIAL_SOL_VOLUME=0.5

# ── Warm-up window ────────────────────────────────────────────────────────────
# Collect at least this many trades before asking Claude to score a token.
# More trades = better momentum signal but slower reaction. Default: 10.
WARM_UP_TRADES=10
# Also fire analysis after this many seconds even if trade count isn't reached.
WARM_UP_SECONDS=20

# ── Set to false to execute REAL trades ───────────────────────────────────────
DRY_RUN=true

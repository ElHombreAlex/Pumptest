# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Solana Wallet ─────────────────────────────────────────────────────────────
# Base58-encoded private key (never share this!)
WALLET_PRIVATE_KEY=your_base58_private_key
WALLET_PUBLIC_KEY=your_wallet_public_key

# ── RPC (Helius/QuickNode strongly recommended for production) ────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── PumpPortal trading API key (optional, reduces fees) ──────────────────────
PUMPPORTAL_API_KEY=

# ── Risk Management ───────────────────────────────────────────────────────────
MAX_BUY_SOL=0.01
MIN_CONFIDENCE_SCORE=70
TAKE_PROFIT_MULTIPLIER=1.5
STOP_LOSS_MULTIPLIER=0.7
MAX_POSITIONS=3
SLIPPAGE=10
PRIORITY_FEE=0.00001

# ── Token Filtering ───────────────────────────────────────────────────────────
ENABLE_AI_FILTER=true
MIN_INITIAL_SOL_VOLUME=0.5

# ── Set to false to execute REAL trades ───────────────────────────────────────
DRY_RUN=true
